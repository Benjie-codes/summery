{
  "manifest_version": 3,
  "name": "Sumly — Page Summarizer",
  "version": "1.0.0",
  "description": "AI-powered page summarizer with key insights and reading time.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "utils/readability.js",
        "utils/sanitize.js",
        "content/content-script.js"
      ]
    }
  ],
  "web_accessible_resources": []
}
