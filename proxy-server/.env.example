# =============================================================================
# Sumly Proxy — Configuration Reference
# =============================================================================
# PRODUCTION: Set these in the Railway dashboard → your project → Variables tab.
# LOCAL DEV:  Copy this file to .env and fill in your values.
# =============================================================================

# --- Port (Railway sets this automatically — do not override on Railway) ---
PORT=3001

# --- CORS: which Chrome extension origins are allowed (REQUIRED) ---
#
# OPTION A — Wildcard (recommended for demos, shared installs, and reviews):
#   Accepts any Chrome extension. Safe because only Chrome extensions can send
#   the chrome-extension:// origin header — browsers enforce this.
ALLOWED_ORIGINS=chrome-extension://*
#
# OPTION B — Specific extension ID (recommended after publishing to Web Store):
#   Find your extension ID at chrome://extensions with the extension loaded.
#   Use this when you want only your published extension to have access.
# ALLOWED_ORIGINS=chrome-extension://YOUR_EXTENSION_ID_HERE
#
# OPTION C — Multiple specific IDs (comma-separated):
# ALLOWED_ORIGINS=chrome-extension://id_one,chrome-extension://id_two

# --- LLM Provider Order (optional, default: gemini,groq,openrouter) ---
LLM_PROVIDER_ORDER=gemini,groq,openrouter

# --- Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_API_KEYS=key_one,key_two   ← multiple keys tried in order on failure
GEMINI_MODEL_CANDIDATES=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=4096

# --- Groq (OpenAI-compatible) ---
GROQ_API_KEY=your_groq_api_key_here
# GROQ_API_KEYS=key_a,key_b
GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenRouter ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_API_KEYS=key_a,key_b
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_HTTP_REFERER=https://sumly-production.up.railway.app
OPENROUTER_APP_TITLE=Sumly proxy

# --- Rate limiting (optional) ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10
UPSTREAM_COOLDOWN_MS=45000
