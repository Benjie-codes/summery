# --- Required for CORS (Chrome extension origin) ---
ALLOWED_ORIGIN=chrome-extension://YOUR_EXTENSION_ID_HERE
PORT=3001

# --- LLM providers: configure at least one. Multiple keys = try in order, then next provider. ---
# Order of providers (comma-separated): gemini | groq | openrouter
LLM_PROVIDER_ORDER=gemini,groq,openrouter

# Gemini: GEMINI_API_KEYS=key1,key2  OR single GEMINI_API_KEY=
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_API_KEYS=key_one,key_two

GEMINI_MODEL_CANDIDATES=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=4096

# Groq (OpenAI-compatible). Multiple keys try in order within the groq step.
# GROQ_API_KEY=
# GROQ_API_KEYS=key_a,key_b
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (OpenAI-compatible). Set referer as required by OpenRouter policy.
# OPENROUTER_API_KEY=
# OPENROUTER_API_KEYS=key_a,key_b
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_APP_TITLE=Sumry proxy

# --- Proxy rate limit (optional) ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10
UPSTREAM_COOLDOWN_MS=45000
